BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

TG_BOT_TOKEN=your_telegram_bot_token_here
TG_CHAT_ID=your_telegram_chat_id_here
# 额外推送群组 (逗号分隔多个群的 Chat ID, 可选)
TG_GROUP_IDS=-1001234567890,-1009876543210

# AI 分析 (通过 OpenAI 兼容接口, 可选 — 不配置则 AI 功能自动禁用)
AI_API_KEY=your_api_key_here
AI_API_BASE=https://your-litellm-proxy.com/v1
AI_MODEL=your-model-name

# CRITICAL 告警 SMTP 降级 (可选 — 不配置则降级为 log.error)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alert@example.com
SMTP_PASS=your_smtp_password_here
ALERT_EMAIL=you@example.com

# 外部心跳 (Dead Man's Switch, 可选)
# 配置后每次扫描成功会 GET 该 URL, 用于 healthchecks.io 或任意 HTTP ping 端点
# 当整个服务器/网络宕机时, 外部服务会因收不到 ping 而告警
HEARTBEAT_URL=https://hc-ping.com/your-uuid-here
